# Copy to .env for local use. Replace every change-me value; never commit .env.
POSTGRES_DB=domus_presence
POSTGRES_USER=domus
POSTGRES_PASSWORD=change-me-local-database-password
DIRECTUS_SECRET=change-me-at-least-32-random-characters
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me-local-admin-password
DIRECTUS_ADMIN_TOKEN=change-me-local-admin-static-token
DIRECTUS_FRONTEND_TOKEN=change-me-local-read-only-frontend-token
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_INTERNAL_URL=http://directus:8055
PUBLIC_SITE_URL=http://localhost:4321
PREVIEW_SITE_URL=http://localhost:4322
CONTENT_SOURCE=directus
PREVIEW_MODE=false
