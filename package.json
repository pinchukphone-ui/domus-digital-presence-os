{
  "name": "domus-digital-presence-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "pnpm --filter @domus/public-web dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm validate:content",
    "validate:content": "tsx packages/testing/src/validate-content.ts",
    "db:migrate": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f infrastructure/database/migrations/001_content_schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f infrastructure/database/seeds/001_mortgage_hub.sql",
    "backup": "bash infrastructure/database/backup.sh",
    "restore": "bash infrastructure/database/restore.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.15.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
