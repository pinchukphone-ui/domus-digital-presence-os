---
import '@domus/design-system/tokens.css';
import '../styles/global.css';
import type { Page } from '@domus/content-model';
import { absoluteUrl, alternatePages } from '@domus/seo';
const { page, allPages, preview = false } = Astro.props as { page: Page; allPages: Page[]; preview?: boolean };
const origin = preview ? (process.env.PREVIEW_SITE_URL ?? 'http://localhost:4322') : (process.env.PUBLIC_SITE_URL ?? 'http://localhost:4321');
const alternates = alternatePages(page, allPages);
const isPolish = page.language === 'pl';
const homePath = isPolish ? '/pl/kredyty-hipoteczne' : '/ru/ipoteka';
const polishPath = isPolish ? page.canonicalPath : (alternates.find((item) => item.language === 'pl')?.path ?? '/pl/kredyty-hipoteczne');
const russianPath = !isPolish ? page.canonicalPath : (alternates.find((item) => item.language === 'ru')?.path ?? '/ru/ipoteka');
---
<!doctype html>
<html lang={page.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{page.title}</title>
    <meta name="description" content={page.metaDescription} />
    <meta name="robots" content={preview ? 'noindex,nofollow,noarchive' : 'index,follow'} />
    <link rel="canonical" href={absoluteUrl(origin, page.canonicalPath)} />
    {alternates.map((item) => <link rel="alternate" hreflang={item.language} href={absoluteUrl(origin, item.path)} />)}
    {alternates.find((item) => item.language === 'pl') && <link rel="alternate" hreflang="x-default" href={absoluteUrl(origin, alternates.find((item) => item.language === 'pl')!.path)} />}
  </head>
  <body>
    <a class="skip-link" href="#content">{isPolish ? 'Przejdź do treści' : 'Перейти к содержанию'}</a>
    {preview && <div class="preview-banner" role="status">PREVIEW{page.previewCandidate && page.contentVersion ? ` · v${page.contentVersion}` : ''} · draft content · noindex</div>}
    <header class="site-header">
      <a class="brand" href={homePath} aria-label={isPolish ? 'DOMUS Global — strona główna' : 'DOMUS Global — главная'}>DOMUS <span>GLOBAL</span></a>
      <nav aria-label={isPolish ? 'Wybór języka' : 'Выбор языка'}>
        <a href={polishPath} hreflang="pl" lang="pl" aria-current={isPolish ? 'page' : undefined} aria-label="Polski">PL</a>
        <a href={russianPath} hreflang="ru" lang="ru" aria-current={!isPolish ? 'page' : undefined} aria-label="Русский">RU</a>
      </nav>
    </header>
    <slot />
    <footer><div><strong>DOMUS GLOBAL</strong><p>{isPolish ? 'Informacje o kredytach hipotecznych w Polsce.' : 'Информация об ипотечных кредитах в Польше.'}</p></div><p>© 2026</p></footer>
  </body>
</html>
