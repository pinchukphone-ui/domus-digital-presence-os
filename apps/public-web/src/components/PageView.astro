---
import type { Page } from '@domus/content-model';
import { ConsultationDemoForm } from './ConsultationDemoForm';
import { MortgageCalculator } from './MortgageCalculator';
const { page } = Astro.props as { page: Page };
const isPolish = page.language === 'pl';
const hasCalculator = page.blocks.some((block) => block.kind === 'calculator');
const calculatorId = isPolish ? 'kalkulator' : 'kalkulyator';
---
<main id="content">
  {page.breadcrumbs.length > 1 && <nav class="breadcrumbs" aria-label={isPolish ? 'Okruszki' : 'Навигационная цепочка'}>
    {page.breadcrumbs.map((item, index) => <>{index === page.breadcrumbs.length - 1 ? <span aria-current="page">{item.label}</span> : <a href={item.href}>{item.label}</a>}{index < page.breadcrumbs.length - 1 && <span aria-hidden="true">/</span>}</>)}
  </nav>}
  {page.blocks.map((block) => block.kind === 'hero' ? (
    <section class="hero">
      <div class="hero__content">
        <p class="eyebrow">DOMUS · Mortgage</p>
        <h1>{block.heading}</h1>
        <p>{block.body}</p>
        {(hasCalculator || page.cta) && <div class="hero__actions">
          {hasCalculator && <a class="button button--primary" href={`#${calculatorId}`}>{isPolish ? 'Oblicz ratę' : 'Рассчитать платёж'}</a>}
          {page.cta && <a class="button button--secondary" href={page.cta.href}>{page.cta.label}</a>}
        </div>}
      </div>
    </section>
  ) : (
    <section class:list={['block', `block--${block.kind}`]} id={block.kind === 'calculator' ? calculatorId : (typeof block.data.formId === 'string' ? block.data.formId : undefined)}>
      {block.heading && (page.blocks.some((item) => item.kind === 'hero') ? <h2>{block.heading}</h2> : <h1>{block.heading}</h1>)}
      {block.body && <p>{block.body}</p>}
      {block.kind === 'calculator' && <MortgageCalculator language={page.language} client:load />}
      {block.kind === 'service' && <ConsultationDemoForm language={page.language} client:load />}
    </section>
  ))}
  {page.links.length > 0 && <section class="links"><h2>{isPolish ? 'Czytaj dalej' : 'Читайте дальше'}</h2><ul>{page.links.map((link) => <li><a href={link.href}>{link.label}<span aria-hidden="true">→</span></a></li>)}</ul></section>}
  {page.cta && <aside class="cta"><p>{isPolish ? 'Potrzebujesz uporządkować kolejne kroki?' : 'Хотите структурировать следующие шаги?'}</p><a href={page.cta.href}>{page.cta.label}</a></aside>}
</main>
